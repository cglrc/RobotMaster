  0x65U,0x74U,0x45U,0x72U,0x72U,0x6FU,0x72U,0x28U,0x29U,0x0AU,0x20U,0x20U,0x20U,
  0x20U,0x7BU,0x0AU,0x20U,0x20U,0x20U,0x20U,0x20U,0x20U,0x20U,0x20U,0x72U,0x65U,
  0x74U,0x75U,0x72U,0x6EU,0x20U,0x65U,0x72U,0x72U,0x6FU,0x72U,0x5FU,0x3BU,0x0AU,
